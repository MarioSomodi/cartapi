{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "CartDatabase": "Host=localhost;Port=5432;Database=cartdb;Username=postgres;Password=postgres"
  },
  "Database": {
    "ApplyMigrationsOnStartup": false
  },
  "Observability": {
    "ServiceName": "Cart.Api",
    "ServiceNamespace": "abysalto",
    "EventDataset": "abysalto.cart.api.log",
    "EnableConsoleTraceExporter": false
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning",
        "LuckyPennySoftware.MediatR.License": "Error"
      }
    }
  },
  "AllowedHosts": "*"
}
